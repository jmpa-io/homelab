# ignore general files.
.DS_Store
.vscode/

# ignore generated files & directories.
/out
package.yml
coverage.*
dist/
*.zip
*.pem
traces.txt
__pycache__

# ignore test files.
/test.sh

# ignore compiled binaries in root.
/main

# Secrets - DO NOT COMMIT
services/k8s/observability/thanos-objstore-secret.yml
**/secrets/*.yml
**/secrets/*.yaml
*.secret.yml
*.secret.yaml

# Terraform - state and secrets must not be committed
terraform/**/.terraform/
terraform/**/.terraform.lock.hcl
terraform/**/terraform.tfstate
terraform/**/terraform.tfstate.backup
terraform/**/terraform.tfvars
terraform/**/tfplan

# Ansible generated files
services/vms/k3s/kubeconfig.yaml
services/vms/k3s/argocd-credentials.txt
