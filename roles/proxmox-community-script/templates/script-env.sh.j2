#!/bin/bash
# {{ ansible_managed }}
# Environment variables for Proxmox VE community script

# Basic configuration
export VERBOSE="{{ pcs_verbose }}"
export CTID="{{ pcs_container_id }}"
export PCT_HOSTNAME="{{ pcs_hostname }}"

# Resources
export PCT_RAM="{{ pcs_ram }}"
export PCT_SWAP="{{ pcs_swap }}"
export PCT_DISK_SIZE="{{ pcs_disk_size }}"
export PCT_CPUS="{{ pcs_cpu_cores }}"

# OS configuration
export PCT_OSTYPE="{{ pcs_os_type }}"
export PCT_OSVERSION="{{ pcs_os_version }}"

# Network
export BRIDGE="{{ pcs_bridge }}"
export NET0="name=eth0,bridge={{ pcs_bridge }},ip={{ pcs_final_static_ip }}/24,gw={{ pcs_final_gateway }}"

# Container options
export PCT_OPTIONS="-features {{ pcs_features }}"
{% if pcs_privileged == "yes" %}
export PRIVILEGED="yes"
{% endif %}

# Advanced options
{% if pcs_advanced_options != "" %}
{{ pcs_advanced_options }}
{% endif %}

# SSH configuration
{% if pcs_ssh_root_password != "" %}
export SSH_ROOT_PASSWORD="{{ pcs_ssh_root_password }}"
{% endif %}

# Non-interactive mode
export DEBIAN_FRONTEND=noninteractive
