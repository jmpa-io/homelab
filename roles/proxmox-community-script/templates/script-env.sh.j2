#!/bin/bash
# {{ ansible_managed }}
# Environment variables for Proxmox VE community script

# Basic configuration
export VERBOSE="{{ verbose }}"
export CTID="{{ container_id }}"
export PCT_HOSTNAME="{{ hostname }}"

# Resources
export PCT_RAM="{{ ram }}"
export PCT_SWAP="{{ swap }}"
export PCT_DISK_SIZE="{{ disk_size }}"
export PCT_CPUS="{{ cpu_cores }}"

# OS configuration
export PCT_OSTYPE="{{ os_type }}"
export PCT_OSVERSION="{{ os_version }}"

# Network
export BRIDGE="{{ bridge }}"
export NET0="name=eth0,bridge={{ bridge }},ip={{ final_static_ip }}/24,gw={{ final_gateway }}"

# Container options
export PCT_OPTIONS="-features {{ features }}"
{% if privileged == "yes" %}
export PRIVILEGED="yes"
{% endif %}

# Advanced options
{% if advanced_options != "" %}
{{ advanced_options }}
{% endif %}

# SSH configuration
{% if ssh_root_password != "" %}
export SSH_ROOT_PASSWORD="{{ ssh_root_password }}"
{% endif %}

# Non-interactive mode
export DEBIAN_FRONTEND=noninteractive
