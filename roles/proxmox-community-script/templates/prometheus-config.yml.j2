# Prometheus Configuration
# Auto-generated by Ansible
# Scrapes OpenTelemetry collectors and Proxmox hosts

global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: 'homelab'
    environment: 'production'

scrape_configs:
  # OpenTelemetry collectors on Proxmox hosts
  - job_name: 'otel-proxmox-hosts'
    static_configs:
      - targets:
{% for host in groups['proxmox_hosts'] %}
        - '{{ hostvars[host]['ansible_host'] }}:8889'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: instance
        regex: '([^:]+):.*'
        replacement: '$1'

  # OpenTelemetry collector on DNS
  - job_name: 'otel-dns'
    static_configs:
      - targets:
{% for host in groups['dns'] | default([]) %}
        - '{{ hostvars[host]['ansible_host'] }}:8889'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: instance
        regex: '([^:]+):.*'
        replacement: '$1'

  # Prometheus self-monitoring
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  # Proxmox VE hosts (node_exporter)
  - job_name: 'proxmox-nodes'
    static_configs:
      - targets:
{% for host in groups['proxmox_hosts'] %}
        - '{{ hostvars[host]['ansible_host'] }}:9100'
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: instance
        regex: '([^:]+):.*'
        replacement: '$1'
